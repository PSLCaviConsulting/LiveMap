# Copy to .env and fill in values
NODE_ENV=production
PORT=3000

# SQLite database path. On Railway, point this at a mounted volume
# (e.g. sqlite:/data/livemap.db with a volume mounted at /data).
DATABASE_URL=sqlite:./data/livemap.db

# JWT cookie secret — generate a long random string for production.
JWT_SECRET=change-me-to-a-long-random-string

# Auth: with no OAUTH_SERVER_URL set (below), the app auto-logs-in a single
# shared admin user everywhere — including on a deployed domain — so it works
# with no sign-in step. Anyone who can reach the URL is that user. Force it
# off with DEV_AUTH=0, or configure OAUTH_SERVER_URL for real auth.
DEV_AUTH=1

# --- Optional: OAuth (leave OAUTH_SERVER_URL blank for open single-user mode) ---
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_OAUTH_PORTAL_URL=
