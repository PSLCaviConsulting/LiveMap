# Copy to .env and fill in values
NODE_ENV=production
PORT=3000

# SQLite database path. On Railway, point this at a mounted volume
# (e.g. sqlite:/data/livemap.db with a volume mounted at /data).
DATABASE_URL=sqlite:./data/livemap.db

# JWT cookie secret — generate a long random string for production.
JWT_SECRET=change-me-to-a-long-random-string

# Set to 1 to auto-login a dev user (bypasses OAuth). Leave unset in production.
DEV_AUTH=1

# --- Optional: Manus / OAuth services (leave blank unless needed) ---
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_OAUTH_PORTAL_URL=
